# ─── Server ────────────────────────────────────────────────────────────────────

# Port the Express server listens on (Railway/Render set this automatically)
PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/chainpulse?retryWrites=true&w=majority

# Comma-separated list of allowed CORS origins (your frontend URL)
# Local:      http://localhost:5173
# Production: https://your-chainpulse-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=development
